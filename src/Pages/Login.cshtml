@page
@model app.Pages.LoginModel

<h2>Dev Login</h2>
<form method="post">
    @Html.AntiForgeryToken()
    <div>
        <label>Name: <input name="name" type="text" /></label>
    </div>
    <div>
        <label>Roles (comma-separated): <input name="roles" type="text" placeholder="employees, beta" /></label>
    </div>
    <button type="submit">Login</button>
</form>
