{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{css,js,png,svg,ico}"
    ]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/login",
      "statusCode": 302
    },
    "404": {
      "redirect": "/not-found",
      "statusCode": 302
    }
  },
  "routes": [
    {
      "route": "/mmm"
    }
  ]
}