{
  "routes": [
    {
      "route": "/instances*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{css,js,png,svg,ico}"
    ]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    },
    "404": {
      "redirect": "/not-found",
      "statusCode": 302
    }
  }, 
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-My-Custom": "header"
  }
}